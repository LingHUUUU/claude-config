{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "ANTHROPIC_BASE_URL": "https://api.xiaomimimo.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "sk-cy4lxrq3fm878zym26h7fopf12h71qwykkl3wonw25p5zzss",
    "ANTHROPIC_MODEL": "mimo-v2.5-pro[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "mimo-v2.5-pro[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "mimo-v2.5-pro[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "mimo-v2.5[1m]",
    "CLAUDE_CODE_SUBAGENT_MODEL": "mimo-v2.5[1m]",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_SIMPLE": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus",
  "skipAutoPermissionPrompt": true,
  "defaultMode": "auto",
  "mcpServers": {
    "git": {
      "command": "npx",
      "args": [
        "@anthropic/mcp-server-git"
      ],
      "type": "stdio"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "type": "stdio"
    },
    "openmemory": {
      "command": "npx",
      "args": [
        "@peakmojo/mcp-openmemory@latest"
      ],
      "type": "stdio"
    },
    "websearch": {
      "command": "npx",
      "args": [
        "-y",
        "agentsweb-mcp"
      ],
      "type": "stdio"
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic/mcp-server-fetch"
      ],
      "type": "stdio"
    },
    "jupyter": {
      "command": "python3",
      "args": [
        "-m",
        "jupyter_mcp_server"
      ],
      "type": "stdio"
    }
  },
  "skipDangerousModePermissionPrompt": true
}
